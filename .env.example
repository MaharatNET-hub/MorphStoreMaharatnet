# انسخ هذا الملف إلى .env على السيرفر واملأ القيم الحقيقية، ثم:
#   set -a && source .env && set +a
# قبل تشغيل bin/setup-server.sh
# لا ترفع ملف .env الحقيقي على git (موجود في .gitignore).

# مسار تنصيب ووردبريس على السيرفر (المجلد الذي يخدمه الويب سيرفر)
WP_PATH=/var/www/maharatnet

# قاعدة البيانات
DB_NAME=maharatnet_store
DB_USER=maharatnet_user
DB_PASS=CHANGE_ME
DB_HOST=localhost
DB_TABLE_PREFIX=wp_

# بيانات الموقع
SITE_URL=https://maharatnet.com
SITE_TITLE="Maharatnet Store"
ADMIN_USER=admin
ADMIN_PASS=CHANGE_ME
ADMIN_EMAIL=support@maharatnet.com

# مسار استنساخ هذا المستودع على السيرفر (يُستخدَم لربط الثيم الابن برمز symlink)
REPO_DIR=/opt/morphstore-maharatnet
REPO_URL=git@github.com:maharatnet-hub/morphstoremaharatnet.git
REPO_BRANCH=main
